ANTHROPIC_API_KEY=your_api_key_here

# Required on public deploys: HTTP Basic password for the whole app
APP_PASSWORD=
# Bearer token for Claude automations (read-only pulls)
AGENT_API_TOKEN=

# Google Drive ingestion (preferred — works anywhere)
# Share the Drive folder with the service account email, then:
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials.json
# or paste the full service-account JSON for cloud deploys:
GOOGLE_DRIVE_CREDENTIALS_JSON=
DRIVE_POLL_INTERVAL_MINUTES=10

# Legacy local mode fallback (only used when GOOGLE_DRIVE_FOLDER_ID is unset)
WATCH_FOLDER=G:\My Drive\Mobile Photo Sync

# Commerce7 read-only proxy (for Claude automations)
C7_APP_ID=
C7_APP_SECRET=
C7_TENANT=
